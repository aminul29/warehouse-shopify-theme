      "blocks": {
        "faq_1": {
          "type": "faq_item",
          "settings": {
            "question": "Do you offer used inventory?",
            "answer": "Yes. Availability changes frequently, but we can source used inventory when it aligns with your scope, timing, and quality requirements."
          }
        },
        "faq_2": {
          "type": "faq_item",
          "settings": {
            "question": "Do you only provide racking systems?",
            "answer": "No. We support warehouse design, product selection, installation, repairs, and broader storage strategy so you can keep one partner from concept to execution."
          }
        },
        "faq_3": {
          "type": "faq_item",
          "settings": {
            "question": "Does it take a long time to get permits for racking installations?",
            "answer": "Permit timelines vary by jurisdiction, but we help streamline the process with fast drawings and permit-aware planning so approvals do not become a hidden blocker."
          }
        },
        "faq_4": {
          "type": "faq_item",
          "settings": {
            "question": "Do you outsource any of your work?",
            "answer": "We coordinate experienced specialists when required, but we stay accountable for the full scope, schedule, and communication throughout the project."
          }
        },
        "faq_5": {
          "type": "faq_item",
          "settings": {
            "question": "Can you help with warehouse automation and optimization?",
            "answer": "Yes. We regularly support clients with automation-ready layouts, density improvements, and system recommendations tied to throughput and labor goals."
          }
        },
        "faq_6": {
          "type": "faq_item",
          "settings": {
            "question": "Do you charge for drawings?",
            "answer": "That depends on project scope and stage, but our process is built to get you the clarity you need quickly. We can outline exactly what is included before work starts."
          }
        },
        "faq_7": {
          "type": "faq_item",
          "settings": {
            "question": "Do you offer warranties on your racking systems?",
            "answer": "Yes. Warranty coverage depends on the product and installation scope. We will provide the applicable coverage terms during quoting."
          }
        },
        "faq_8": {
          "type": "faq_item",
          "settings": {
            "question": "How soon can you install new projects?",
            "answer": "For many scopes, we can move from quote to install far faster than traditional providers. Final timing depends on site readiness, permits, and project size."
          }
        },
        "faq_9": {
          "type": "faq_item",
          "settings": {
            "question": "Where are you located? Do you work only in Texas or do you offer national service?",
            "answer": "We support projects nationwide. If your operation is outside Texas, we can still assess the site, plan the system, and coordinate delivery and install."
          }
        }
