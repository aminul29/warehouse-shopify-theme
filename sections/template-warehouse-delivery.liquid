{% liquid
  assign delivery_alt = section.settings.image.alt | default: section.settings.heading
%}

<section
  id="delivery"
  class="bg-[#1493F5] py-8 text-white sm:py-10"
  aria-label="{{ section.settings.aria_label | escape }}"
  data-delivery-section>
  <div class="section-wrap flex flex-col items-center justify-center gap-7 text-center sm:flex-row sm:gap-10">
    {% if section.settings.image != blank %}
      <div class="shrink-0" data-delivery-truck-wrap>
        {{
          section.settings.image
          | image_url: width: 640
          | image_tag: widths: '180, 240, 320, 480, 640', sizes: '(min-width: 1024px) 370px, (min-width: 640px) 240px, 44vw', alt: delivery_alt, class: 'delivery-truck', loading: 'lazy'
        }}
      </div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2
        class="section-title max-w-full text-[52px] text-white sm:min-w-[20ch] sm:max-w-[15ch] sm:text-left"
        data-delivery-heading>
        {{ section.settings.heading }}
      </h2>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Warehouse Delivery Banner",
  "tag": "section",
  "class": "section-warehouse-delivery",
  "enabled_on": {
    "templates": ["index"]
  },
  "settings": [
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Delivery banner"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Truck image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Next Day Delivery at the Speed You Need"
    }
  ],
  "presets": [
    {
      "name": "Warehouse Delivery Banner"
    }
  ]
}
{% endschema %}
