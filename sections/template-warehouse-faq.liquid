<section
  id="{{ section.settings.section_id | default: 'faqs' | handleize }}"
  class="relative overflow-hidden bg-white py-20 sm:py-28"
  aria-label="{{ section.settings.aria_label | escape }}"
>
  <div class="section-wrap relative max-w-[768px]">
    <div class="text-center">
      {% if section.settings.heading != blank %}
        <h2 class="section-title text-slate-950">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="section-subtitle mt-5 text-lg leading-8">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div id="faq-list-{{ section.id }}" class="faq-list mt-20" data-allow-multiple="{{ section.settings.allow_multiple_open }}">
        {% for block in section.blocks %}
          {% liquid
            assign button_id = 'faq-trigger-' | append: section.id | append: '-' | append: block.id
            assign panel_id = 'faq-panel-' | append: section.id | append: '-' | append: block.id
            assign is_open = false
            if section.settings.first_item_open and forloop.first
              assign is_open = true
            endif
          %}

          <div class="faq-item" data-open="{{ is_open }}" {{ block.shopify_attributes }}>
            <button
              id="{{ button_id }}"
              type="button"
              class="faq-trigger"
              aria-expanded="{{ is_open }}"
              aria-controls="{{ panel_id }}"
            >
              <span>{{ block.settings.question }}</span>
              <span class="faq-icon" aria-hidden="true"><i class="fa-solid fa-chevron-down"></i></span>
            </button>
            <div id="{{ panel_id }}" class="faq-panel" role="region" aria-labelledby="{{ button_id }}">
              <div class="overflow-hidden pb-5 pr-12 text-[16px] text-slate-600">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% javascript %}
  (() => {
    const sectionId = '{{ section.id }}';
    const root = document.getElementById('faq-list-' + sectionId);
    if (!root) return;

    const allowMultiple = root.dataset.allowMultiple === 'true';
    const items = Array.from(root.querySelectorAll('.faq-item'));

    const setOpenState = (item, isOpen) => {
      item.dataset.open = isOpen ? 'true' : 'false';
      const trigger = item.querySelector('.faq-trigger');
      if (trigger) trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    };

    const closeSiblings = (activeItem) => {
      if (allowMultiple) return;
      items.forEach((item) => {
        if (item !== activeItem) setOpenState(item, false);
      });
    };

    items.forEach((item) => {
      const trigger = item.querySelector('.faq-trigger');
      if (!trigger) return;

      trigger.addEventListener('click', () => {
        const isCurrentlyOpen = item.dataset.open === 'true';
        closeSiblings(item);
        setOpenState(item, !isCurrentlyOpen);
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Warehouse FAQ",
  "tag": "section",
  "class": "section-warehouse-faq",
  "enabled_on": {
    "templates": ["index"]
  },
  "settings": [
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Frequently asked questions"
    },
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID (for CSS anchor links)",
      "default": "faqs"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Find answers to common questions about us."
    },
    {
      "type": "checkbox",
      "id": "allow_multiple_open",
      "label": "Allow multiple items open",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "first_item_open",
      "label": "Open first item by default",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Do you offer used inventory?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Yes. Availability changes frequently, but we can source used inventory when it aligns with your scope, timing, and quality requirements."
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Warehouse FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "Do you offer used inventory?",
            "answer": "Yes. Availability changes frequently, but we can source used inventory when it aligns with your scope, timing, and quality requirements."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Do you only provide racking systems?",
            "answer": "No. We support warehouse design, product selection, installation, repairs, and broader storage strategy so you can keep one partner from concept to execution."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Can you help with warehouse automation and optimization?",
            "answer": "Yes. We regularly support clients with automation-ready layouts, density improvements, and system recommendations tied to throughput and labor goals."
          }
        }
      ]
    }
  ]
}
{% endschema %}
