<section
  id="solutions"
  class="bg-white py-20 sm:py-28 lg:py-[110px]"
  aria-label="{{ section.settings.aria_label | escape }}"
  data-next-section
>
  <div class="section-wrap">
    <div class="mx-auto max-w-[650px] text-center">
      {% if section.settings.heading != blank %}
        <h2 class="section-title mt-4">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="section-subtitle mt-5 text-lg leading-8">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="mt-20 grid gap-6 lg:grid-cols-3">
        {% for block in section.blocks %}
          {% liquid
            assign card_alt = block.settings.icon.alt | default: block.settings.title
          %}
          <article class="card-surface card-pad card-plain text-center" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              {{
                block.settings.icon
                | image_url: width: 96
                | image_tag:
                  widths: '64, 96, 128',
                  sizes: '(min-width: 1024px) 96px, 64px',
                  alt: card_alt,
                  class: 'mx-auto h-16 w-auto',
                  loading: 'lazy'
              }}
            {% endif %}

            {% if block.settings.title != blank %}
              <h3 class="mt-6 font-heading text-3xl uppercase leading-none">{{ block.settings.title }}</h3>
            {% endif %}

            {% if block.settings.body != blank %}
              <p class="mt-4 text-base leading-7">{{ block.settings.body }}</p>
            {% endif %}

            {% if block.settings.button_label != blank and block.settings.button_url != blank %}
              <a class="btn-primary mt-8" href="{{ block.settings.button_url }}">{{ block.settings.button_label }}</a>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Warehouse Solutions",
  "tag": "section",
  "class": "section-warehouse-solutions",
  "enabled_on": {
    "templates": ["index"]
  },
  "settings": [
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Warehouse solutions"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Comprehensive Warehouse Solutions"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "With a broad level of expertise, DPR can serve as the single point of contact for your warehouse project."
    }
  ],
  "blocks": [
    {
      "type": "solution",
      "name": "Solution card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Warehouse Design"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Expert space-planning consultation designed around your layout, throughput, and inventory profile."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Explore"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button link"
        }
      ]
    }
  ],
  "max_blocks": 9,
  "presets": [
    {
      "name": "Warehouse Solutions",
      "blocks": [
        {
          "type": "solution",
          "settings": {
            "title": "Warehouse Design",
            "body": "Expert space-planning consultation designed around your layout, throughput, and inventory profile.",
            "button_label": "Explore"
          }
        },
        {
          "type": "solution",
          "settings": {
            "title": "Racking & Storage",
            "body": "A broad selection of products to build a customized storage system that fits now and scales later.",
            "button_label": "Explore"
          }
        },
        {
          "type": "solution",
          "settings": {
            "title": "Installation",
            "body": "Installation services for projects of every size, including repairs, adjustments, and phased rollouts.",
            "button_label": "Explore"
          }
        }
      ]
    }
  ]
}
{% endschema %}
