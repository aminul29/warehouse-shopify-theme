<section
  id="advantages"
  class="relative overflow-hidden bg-white py-20 sm:py-28"
  aria-label="{{ section.settings.aria_label | escape }}">
  {% if section.settings.show_top_gradient %}
    <div class="pointer-events-none absolute inset-x-0 top-0 h-48 bg-gradient-to-b from-slate-50 to-transparent"></div>
  {% endif %}

  {% if section.blocks.size > 0 %}
    <div class="section-wrap feature-grid">
      {% for block in section.blocks %}
        {% liquid
          assign media_alt = block.settings.media_image.alt | default: block.settings.title
          assign accent_alt = block.settings.accent_image.alt | default: block.settings.eyebrow
          assign row_classes = 'feature-row feature-row-decorated'
          if block.settings.reverse_layout
            assign row_classes = row_classes | append: ' feature-row-right reverse'
          else
            assign row_classes = row_classes | append: ' feature-row-left'
          endif

          assign accent_class = ''
          case block.settings.accent_position
            when 'left'
              assign accent_class = 'feature-hexagon feature-hexagon-left'
            when 'middle'
              assign accent_class = 'feature-hexagon feature-hexagon-middle'
            when 'left_bottom'
              assign accent_class = 'feature-hexagon feature-hexagon-left-bottom absolute left-0 bottom-0'
          endcase
        %}

        <article class="{{ row_classes }}" {{ block.shopify_attributes }}>
          {% if block.settings.accent_image != blank and accent_class != blank %}
            {{
              block.settings.accent_image
              | image_url: width: 900
              | image_tag: widths: '320, 640, 900', sizes: '(min-width: 1024px) 320px, 180px', alt: accent_alt, class: accent_class, loading: 'lazy'
            }}
          {% endif %}

          {% if block.settings.media_image != blank %}
            {% liquid
              assign media_class = 'feature-media'
              if block.settings.reverse_layout
                assign media_class = media_class | append: ' order-1 lg:order-2'
              endif
            %}
            {{
              block.settings.media_image
              | image_url: width: 1600
              | image_tag: widths: '540, 720, 960, 1280, 1600', sizes: '(min-width: 1024px) 40vw, 100vw', alt: media_alt, class: media_class, loading: 'lazy'
            }}
          {% endif %}

          {% if block.settings.reverse_layout %}
            <div class="order-2 lg:order-1">
              {% if block.settings.eyebrow != blank %}
                <p class="eyebrow">{{ block.settings.eyebrow }}</p>
              {% endif %}
              {% if block.settings.title != blank %}
                <h2 class="mt-4 text-left font-heading text-[40px] font-extrabold uppercase leading-[105%] text-[#111]">{{ block.settings.title }}</h2>
              {% endif %}
              {% if block.settings.body != blank %}
                <p class="mt-6 max-w-2xl leading-8">{{ block.settings.body }}</p>
              {% endif %}
            </div>
          {% else %}
            <div>
              {% if block.settings.eyebrow != blank %}
                <p class="eyebrow">{{ block.settings.eyebrow }}</p>
              {% endif %}
              {% if block.settings.title != blank %}
                <h2 class="mt-4 text-left font-heading text-[40px] font-extrabold uppercase leading-[105%] text-[#111]">{{ block.settings.title }}</h2>
              {% endif %}
              {% if block.settings.body != blank %}
                <p class="mt-6 max-w-2xl leading-8">{{ block.settings.body }}</p>
              {% endif %}
            </div>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Warehouse Advantages",
  "tag": "section",
  "class": "section-warehouse-advantages",
  "enabled_on": {
    "templates": ["index"]
  },
  "settings": [
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Warehouse advantages"
    },
    {
      "type": "checkbox",
      "id": "show_top_gradient",
      "label": "Show top gradient",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "advantage",
      "name": "Advantage",
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Speed"
        },
        {
          "type": "textarea",
          "id": "title",
          "label": "Title",
          "default": "No Downtime, Just Results"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "With rapid design and installation, you'll experience minimal downtime. No delays, no stock issues, and no costly disruption while your team waits for a supplier to move."
        },
        {
          "type": "image_picker",
          "id": "media_image",
          "label": "Main image"
        },
        {
          "type": "image_picker",
          "id": "accent_image",
          "label": "Decorative image"
        },
        {
          "type": "select",
          "id": "accent_position",
          "label": "Decorative image position",
          "default": "left",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "middle", "label": "Middle" },
            { "value": "left_bottom", "label": "Left bottom" }
          ]
        },
        {
          "type": "checkbox",
          "id": "reverse_layout",
          "label": "Reverse layout on desktop",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Warehouse Advantages",
      "blocks": [
        {
          "type": "advantage",
          "settings": {
            "eyebrow": "Speed",
            "title": "No Downtime, Just Results",
            "body": "With rapid design and installation, you'll experience minimal downtime. No delays, no stock issues, and no costly disruption while your team waits for a supplier to move.",
            "accent_position": "left",
            "reverse_layout": false
          }
        },
        {
          "type": "advantage",
          "settings": {
            "eyebrow": "Experience",
            "title": "Over 1,000 Successful Projects",
            "body": "We've designed and installed storage solutions in more than 1,000 warehouses nationwide. That experience translates into fewer mistakes, faster decisions, and cleaner execution.",
            "accent_position": "middle",
            "reverse_layout": true
          }
        },
        {
          "type": "advantage",
          "settings": {
            "eyebrow": "Expertise",
            "title": "End-to-End Project Management",
            "body": "From concept and permits to execution, we handle every step so your project stays on track. The result is a fast, seamless rollout without unnecessary complexity.",
            "accent_position": "left_bottom",
            "reverse_layout": false
          }
        }
      ]
    }
  ]
}
{% endschema %}
