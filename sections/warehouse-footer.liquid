{% liquid
  assign current_year = 'now' | date: '%Y'
  assign primary_links = blank
  assign legal_links = blank

  if section.settings.primary_menu != blank and linklists[section.settings.primary_menu] != blank
    assign primary_links = linklists[section.settings.primary_menu].links
  endif

  if section.settings.legal_menu != blank and linklists[section.settings.legal_menu] != blank
    assign legal_links = linklists[section.settings.legal_menu].links
  endif
%}

<footer
  class="bg-paper py-10"
  role="contentinfo"
  aria-label="{{ section.settings.aria_label | escape }}">
  <div class="section-wrap">
    <div class="flex flex-col items-center justify-between gap-6 border-b border-slate-200 pb-8 lg:flex-row">
      {% if section.settings.logo_image != blank %}
        {{
          section.settings.logo_image
          | image_url: width: 400
          | image_tag: widths: '160, 240, 320, 400', sizes: '(min-width: 1024px) 220px, 160px', alt: section.settings.logo_alt
          | default: shop.name, class: 'h-[52px] w-auto shrink-0 p-2'
        }}
      {% elsif section.settings.logo_text != blank %}
        <p class="text-lg font-extrabold uppercase text-slate-900">{{ section.settings.logo_text }}</p>
      {% endif %}

      {% if primary_links != blank %}
        <nav
          class="flex flex-wrap items-center justify-center gap-5 text-center font-['Aptos'] text-[18px] leading-[22px] font-normal text-[#111]"
          aria-label="{{ section.settings.primavry_nav_label | escape }}">
          {% for link in primary_links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        </nav>
      {% endif %}

      {% if section.settings.phone_text != blank %}
        {% liquid
          assign phone_href = section.settings.phone_url
          if phone_href == blank
            assign sanitized_phone = section.settings.phone_text | remove: ' ' | remove: '-' | remove: '(' | remove: ')' | remove: '.'
            assign phone_href = 'tel:' | append: sanitized_phone
          endif
        %}
        <a class="text-sm font-extrabold text-slate-900" href="{{ phone_href }}">
          {{ section.settings.phone_text }}
        </a>
      {% endif %}
    </div>

    <div class="flex flex-col gap-4 pt-6 text-center text-sm lg:flex-row lg:items-center lg:justify-between lg:text-left">
      {% if section.settings.copyright_text != blank %}
        <p>{{ section.settings.copyright_text | replace: '{year}', current_year }}</p>
      {% endif %}

      {% if legal_links != blank %}
        <div class="flex flex-wrap justify-center gap-4 lg:justify-end">
          {% for link in legal_links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Warehouse Footer",
  "tag": "section",
  "class": "section-warehouse-footer",
  "settings": [
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Footer"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Logo image alt text",
      "default": "Direct Pallet Racking"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text fallback",
      "default": "Direct Pallet Racking"
    },
    {
      "type": "text",
      "id": "primary_nav_label",
      "label": "Primary navigation accessibility label",
      "default": "Footer navigation"
    },
    {
      "type": "link_list",
      "id": "primary_menu",
      "label": "Primary menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Legal menu"
    },
    {
      "type": "text",
      "id": "phone_text",
      "label": "Phone text",
      "default": "888-979-9824"
    },
    {
      "type": "url",
      "id": "phone_url",
      "label": "Phone link override"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "&copy; {year} Direct Pallet Racking. All rights reserved."
    }
  ]
}
{% endschema %}
