{% liquid
  assign hero_alt = section.settings.background_image.alt | default: section.settings.heading
%}

<section id="hero" class="relative isolate overflow-hidden" aria-label="{{ section.settings.aria_label | escape }}">
  {% if section.settings.background_image != blank %}
    {{
      section.settings.background_image
      | image_url: width: 2400
      | image_tag: widths: '750, 1100, 1500, 1780, 2000, 2400', sizes: '100vw', alt: hero_alt, loading: 'eager', fetchpriority: 'high', class: 'absolute inset-0 h-full w-full object-cover'
    }}
  {% else %}
    <div class="absolute inset-0 bg-slate-900"></div>
  {% endif %}

  <div class="absolute inset-0 bg-slate-950/55"></div>

  <div class="section-wrap relative flex min-h-[78svh] items-center justify-center py-16 text-center sm:min-h-[720px]">
    <div class="max-w-4xl">
      {% if section.settings.heading != blank %}
        <h1 class="hero-title max-w-4xl">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="hero-copy mx-auto mt-6 max-w-2xl">{{ section.settings.subheading }}</p>
      {% endif %}

      {% if section.settings.primary_button_label != blank or section.settings.secondary_button_label != blank %}
        <div class="mt-15 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          {% if section.settings.primary_button_label != blank and section.settings.primary_button_url != blank %}
            <a class="btn-primary" href="{{ section.settings.primary_button_url }}">
              {{ section.settings.primary_button_label }}
            </a>
          {% endif %}

          {% if section.settings.secondary_button_label != blank and section.settings.secondary_button_url != blank %}
            <a class="btn-secondary" href="{{ section.settings.secondary_button_url }}">
              {{ section.settings.secondary_button_label }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Warehouse Hero",
  "tag": "section",
  "class": "section-warehouse-hero",
  "settings": [
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Hero section"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "America's Leading Warehouse Storage Experts"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Don't settle for less. Get the best racking solution now."
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "primary_button_url",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "secondary_button_url",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Warehouse Hero"
    }
  ]
}
{% endschema %}
